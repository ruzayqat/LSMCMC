#!/bin/bash
# postBuild - Binder post-installation script
# This runs after the environment is created but before the notebook starts.

# Download pre-computed output data for figure reproduction
# (Skip if already present or if Zenodo ID not configured)
if python3 -c "from download_output_data import ZENODO_RECORD_ID; exit(0 if ZENODO_RECORD_ID != 'XXXXXXX' else 1)" 2>/dev/null; then
    echo "Downloading pre-computed output data for figure reproduction..."
    python3 download_output_data.py --noninteractive || echo "Download skipped or failed; figures requiring output data will not work."
else
    echo "Note: Output data not configured. Linear Gaussian experiment will work; MLSWE figures require running experiments locally."
fi
